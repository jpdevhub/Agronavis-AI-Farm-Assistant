# =============================================================================
# AgroNavis — .gitignore
# =============================================================================

# ─── Dependencies ─────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ─── Build outputs ────────────────────────────────────────────────────────────
.next/
out/
build/
dist/
*.tsbuildinfo

# ─── Environment files — NEVER commit secrets ─────────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
backend/.env
frontend/.env.local

# ─── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─── Cache ────────────────────────────────────────────────────────────────────
.cache/
.parcel-cache/
.eslintcache
.turbo

# ─── Python (ML service — future) ────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
ENV/
.venv/

# ─── ML model files ───────────────────────────────────────────────────────────
*.pt
*.onnx
*.h5
*.pkl

# ─── OS metadata ──────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ─── IDE ──────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ─── Database ─────────────────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3

# ─── Test coverage ────────────────────────────────────────────────────────────
coverage/
*.lcov
.nyc_output

# ─── Supabase local state ─────────────────────────────────────────────────────
backend/supabase/.branches
backend/supabase/.temp

# ─── Deployment ───────────────────────────────────────────────────────────────
.vercel
.dockerignore

# ─── Misc ─────────────────────────────────────────────────────────────────────
debug-*.html